{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "giasutainang",
  "compatibility_date": "2026-07-09",
  "assets": {
    "directory": "./out",
    "not_found_handling": "404-page",
    "html_handling": "auto-trailing-slash"
  },
  "routes": [
    {
      "pattern": "giasutainang.online",
      "custom_domain": true
    },
    {
      "pattern": "www.giasutainang.online",
      "custom_domain": true
    }
  ]
}
